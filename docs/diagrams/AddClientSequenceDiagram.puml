@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":AddClientCommand" as AddClientCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":ModelManager" as ModelManager MODEL_COLOR
participant ":AddressBook" as AddressBook MODEL_COLOR
end box

[-> AddClientCommand : execute(model)
activate AddClientCommand

AddClientCommand -> ModelManager : hasPerson(toAdd)
activate ModelManager

ModelManager -> AddressBook : hasPerson(toAdd)
activate AddressBook

AddressBook --> ModelManager
deactivate AddressBook

ModelManager --> AddClientCommand
deactivate ModelManager

AddClientCommand -> ModelManager : addPerson(toAdd)
activate ModelManager

ModelManager -> AddressBook : addPerson(toAdd)
activate AddressBook

AddressBook --> ModelManager
deactivate AddressBook

ModelManager --> AddClientCommand
deactivate ModelManager

[<-- AddClientCommand : new CommandResult(...)
deactivate AddClientCommand
@enduml
