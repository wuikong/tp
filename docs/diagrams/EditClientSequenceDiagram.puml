@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":EditClientCommand" as EditClientCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":ModelManager" as ModelManager MODEL_COLOR
participant ":AddressBook" as AddressBook MODEL_COLOR
end box

[-> EditClientCommand : execute(model)
activate EditClientCommand

EditClientCommand -> ModelManager : getFilteredPersonList()
activate ModelManager
ModelManager --> EditClientCommand : lastShownList
deactivate ModelManager

EditClientCommand -> ModelManager : setPerson(personToEdit, editedPerson)
activate ModelManager
ModelManager -> AddressBook : setPerson(...)
activate AddressBook
AddressBook --> ModelManager
deactivate AddressBook
ModelManager --> EditClientCommand
deactivate ModelManager

[<-- EditClientCommand : new CommandResult(...)
deactivate EditClientCommand
@enduml
