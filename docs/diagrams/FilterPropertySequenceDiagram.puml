@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":FilterPropertyCommand" as FilterPropertyCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":ModelManager" as ModelManager MODEL_COLOR
participant ":FilteredList<Property>" as FilteredProperties MODEL_COLOR
participant ":FilteredList<Person>" as FilteredPersons MODEL_COLOR
end box

[-->FilterPropertyCommand : execute(...)
activate FilterPropertyCommand

FilterPropertyCommand -> ModelManager : updateFilteredPropertyList(predicate)
activate ModelManager

ModelManager -> FilteredProperties : setPredicate(predicate)
activate FilteredProperties

FilteredProperties --> ModelManager
deactivate FilteredProperties

ModelManager --> FilterPropertyCommand
deactivate ModelManager

FilterPropertyCommand -> ModelManager : updateFilteredPersonList(pred)
activate ModelManager

ModelManager -> FilteredPersons : setPredicate(ownersOfFilteredProperties)
activate FilteredPersons

FilteredPersons --> ModelManager
deactivate FilteredPersons

ModelManager --> FilterPropertyCommand
deactivate ModelManager

[<--FilterPropertyCommand : new CommandResult(...)
deactivate FilterPropertyCommand
@enduml
