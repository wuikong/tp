@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":SortPropertyCommandParser" as SortPropertyCommandParser LOGIC_COLOR
participant "s:SortPropertyCommand" as SortPropertyCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("sortProperty s/price o/up")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("sortProperty s/price o/up")
activate AddressBookParser

create SortPropertyCommandParser
AddressBookParser -> SortPropertyCommandParser
activate SortPropertyCommandParser

SortPropertyCommandParser --> AddressBookParser
deactivate SortPropertyCommandParser

AddressBookParser -> SortPropertyCommandParser : parse(" s/price o/up")
activate SortPropertyCommandParser

create SortPropertyCommand
SortPropertyCommandParser -> SortPropertyCommand
activate SortPropertyCommand

SortPropertyCommand --> SortPropertyCommandParser :
deactivate SortPropertyCommand

SortPropertyCommandParser --> AddressBookParser : s
deactivate SortPropertyCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
SortPropertyCommandParser -[hidden]-> AddressBookParser
destroy SortPropertyCommandParser

AddressBookParser --> LogicManager : s
deactivate AddressBookParser

LogicManager -> SortPropertyCommand : execute(m)
activate SortPropertyCommand

SortPropertyCommand -> Model : sortPropertyList(comparator)
activate Model

Model --> SortPropertyCommand
deactivate Model

create CommandResult
SortPropertyCommand -> CommandResult
activate CommandResult

CommandResult --> SortPropertyCommand
deactivate CommandResult

SortPropertyCommand --> LogicManager : r
deactivate SortPropertyCommand

[<--LogicManager
deactivate LogicManager
@enduml
